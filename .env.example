# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL=

# Bureau of Economic Analysis API Key (https://apps.bea.gov/api/signup/)
BEA_API_KEY=

# Federal Reserve Economic Data API Key (https://fred.stlouisfed.org/api_key.html)
FRED_API_KEY=

# Elsevier ScienceDirect/Scopus Metadata Key (https://dev.elsevier.com/)
ELSEVIER_API_KEY=

# NASA JPL Planetary Data System Key (https://api.nasa.gov/)
NASA_API_KEY=

# Badan Pusat Statistik (BPS) Indonesia API Key (https://bps.go.id/)
BPS_API_KEY=

SPRINGER_META_KEY=

SPRINGER_OA_KEY=

NEXT_PUBLIC_APPWRITE_PROJECT_ID=
NEXT_PUBLIC_APPWRITE_PROJECT_NAME=
NEXT_PUBLIC_APPWRITE_ENDPOINT=
